# Database
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlasqueue

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-api-key-change-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENABLE_DOCS=true
RATE_LIMIT_PER_MINUTE=120
METRICS_REQUIRE_AUTH=false

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin-change-me

# Worker
WORKER_ID=
WORKER_TASKS_MODULE=atlasqueue.worker.example_tasks
WORKER_CONCURRENCY=4
WORKER_API_KEY=dev-api-key-change-in-production
WORKER_HEARTBEAT_INTERVAL=10

# Scheduler
SCHEDULER_TICK_INTERVAL=1
SCHEDULER_LOCK_TTL=30
SCHEDULER_BATCH_SIZE=100

# Observability
LOG_LEVEL=INFO
LOG_JSON=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=atlasqueue

# Security
BLOCK_PRIVATE_WEBHOOK_URLS=true
